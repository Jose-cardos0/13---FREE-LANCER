# Configuração API Voxuy - Integração PIX
# Copie para .env e preencha os valores

# URL do webhook (Integrações → API VOXUY)
VOXUY_WEBHOOK_URL=https://sistema.voxuy.com/api/bc608452-e9b7-4213-9ee3-2ea983bd995e/webhooks/voxuy/transaction

# Token da API (Integrações → API VOXUY)
VOXUY_API_TOKEN=8c01c758-2f53-42e5-82e7-9465185d7341

# ID do plano (Produtos → seu produto → Copiar código do plano)
VOXUY_PLAN_ID=7e50b0e6-3554-4b10-84c4-0bc7d7

# (Opcional) ID do evento personalizado, se estiver usando evento customizado
# VOXUY_CUSTOM_EVENT_ID=63
